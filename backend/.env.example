# Copy this file to .env in the same folder (backend/.env) and fill in values.
# Never commit .env — it contains secrets.

# Region where bedrock-mantle is enabled (must match Bedrock console)
AWS_DEFAULT_REGION=eu-north-1

# Bedrock API key — Console → Amazon Bedrock → API keys
OPENAI_API_KEY=

# Optional — auto-built from region if omitted
OPENAI_BASE_URL=https://bedrock-mantle.eu-north-1.api.aws/v1

# Model ID from the Bedrock console (Use model)
BEDROCK_MODEL_ID=deepseek.v3.2
